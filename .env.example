GOMI_ADMIN_USERNAME=admin
GOMI_ADMIN_PASSWORD=changeme
VITE_GOMI_BOOTSTRAP_USERNAME=admin
VITE_GOMI_BOOTSTRAP_PASSWORD=changeme

# Optional YAML config file for the gomi server process.
# GOMI_CONFIG=/etc/gomi/gomi.yaml

# DNS integration. Explicitly set to embedded to run GOMI's authoritative DNS server.
GOMI_DNS_MODE=off
# GOMI_DNS_EMBEDDED_ADDR=:53
# GOMI_DNS_TTL=300s
# RFC2136 dynamic DNS mode. TSIG secret is base64.
# GOMI_RFC2136_SERVER=192.0.2.53:53
# GOMI_RFC2136_ZONE=lab.example
# GOMI_RFC2136_TSIG_NAME=gomi-key
# GOMI_RFC2136_TSIG_SECRET=
# GOMI_RFC2136_TSIG_ALGORITHM=hmac-sha256.
# GOMI_RFC2136_TRANSPORT=udp

# Debian package version is read from packages/debian/changelog.
ARCH=amd64
HOST=user@127.0.0.1
# Optional: use a different host for remote .deb assembly.
# DEB_BUILD_HOST=user@127.0.0.1
# REMOTE_DEB_WORK=/tmp/gomi-deb-build
GOMI_URL=http://127.0.0.1:5392
TFTP_ROOT=/var/lib/gomi/tftp/linux
BASE_INITRD=/var/lib/gomi/tftp/ubuntu/initrd
RUNTIME_CLOUD_IMAGE=/var/lib/gomi/images/ubuntu-24.04.img
REMOTE_WORK=/tmp/gomi-initrd-build
