{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gomi.invalid/schemas/os-catalog.schema.json",
  "oneOf": [
    {
      "type": "object",
      "required": ["entries"],
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entry"
          }
        }
      }
    },
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    {
      "$ref": "#/$defs/entry"
    }
  ],
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["name", "osFamily", "osVersion", "arch", "format", "url", "bootEnvironment"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "format": { "const": "raw" }
            },
            "required": ["format"]
          },
          "then": {
            "properties": {
              "sourceCompression": {
                "enum": ["zstd", ""]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "format": { "const": "squashfs" }
            },
            "required": ["format"]
          },
          "then": {
            "properties": {
              "sourceCompression": {
                "const": ""
              }
            }
          }
        }
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "osFamily": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "osVersion": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "arch": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "format": {
          "enum": ["raw", "squashfs"]
        },
        "sourceFormat": {
          "enum": ["raw", "squashfs"]
        },
        "sourceCompression": {
          "type": "string"
        },
        "variant": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "checksum": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "bootEnvironment": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        }
      }
    }
  }
}
